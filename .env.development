# Disable source-map-loader in development to suppress "Failed to parse source
# map" warnings from packages (e.g. posthog-js) that ship source maps
# referencing TypeScript source files not included in their npm distribution.
# Note: webpack still generates inline source maps for this project's own code
# via the cheap-module-source-map devtool, so debugging is unaffected.
GENERATE_SOURCEMAP=false
